{
  "name": "argocd-diff-action",
  "version": "0.7.3",
  "private": true,
  "description": "ArgoCD Diff GitHub Action",
  "main": "src/main.ts",
  "pre-commit": [
    "precommit-msg",
    "lint:fix"
  ],
  "type": "module",
  "scripts": {
    "build": "ncc build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "precommit-msg": "echo 'Running pre-commit hooks..' && exit 0",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/argocd-diff-action/argocd-diff-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "argocd"
  ],
  "author": "argocd-diff-action",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.13.3",
    "@vercel/ncc": "^0.44.1",
    "@vitest/coverage-v8": "^4.1.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "eslint": "^10.7.0",
    "fetch-mock": "^12.6.0",
    "globals": "^17.7.0",
    "js-yaml": "^5.2.1",
    "pre-commit": "^2.0.0",
    "semantic-release": "^25.0.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
